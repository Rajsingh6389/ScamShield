{
  "manifest_version": 3,
  "name": "ScamShield Job Scanner",
  "version": "1.0",
  "description": "Scan job listings on any platform like LinkedIn for potential scams in one click.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan Page with ScamShield"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ]
}
